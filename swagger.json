  "components": {
    "schemas": {
      "BattleAction": {
        "type": "object",
        "properties": {
          "unitName": {
            "type": "string",
            "nullable": true
          },
          "unitType": {
            "$ref": "#/components/schemas/UnitType"
          },
          "actionType": {
            "$ref": "#/components/schemas/BattleActionType"
          },
          "target": {
            "type": "string",
            "nullable": true
          },
          "amount": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "destination": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "BattleActionType": {
        "enum": [
          0,
          1,
          2,
          3,
          4
        ],
        "type": "integer",
        "format": "int32"
      },
      "BattleResult": {
        "type": "object",
        "properties": {
          "battleId": {
            "type": "string",
            "nullable": true
          },
          "winner": {
            "type": "string",
            "nullable": true
          },
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BattleAction"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CalculateBattleWithSpecificUnitTypes": {
        "type": "object",
        "properties": {
          "battle-id": {
            "type": "string",
            "nullable": true
          },
          "unit-type-A": {
            "$ref": "#/components/schemas/UnitType"
          },
          "unit-type-B": {
            "$ref": "#/components/schemas/UnitType"
          }
        },
        "additionalProperties": false
      },
      "RandomBattle": {
        "type": "object",
        "properties": {
          "battle-id": {
            "type": "string",
            "nullable": true
          },
          "team-a": {
            "$ref": "#/components/schemas/Team"
          },
          "team-B": {
            "$ref": "#/components/schemas/Team"
          }
        },
        "additionalProperties": false
      },
      "Team": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "units": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Unit"
            },
            "nullable": true
          },
          "aliveUnits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Unit"
            },
            "nullable": true,
            "readOnly": true
          },
          "isAnyoneAlive": {
            "type": "boolean",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "Unit": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/UnitType"
          },
          "attack": {
            "type": "integer",
            "format": "int32"
          },
          "defence": {
            "type": "integer",
            "format": "int32"
          },
          "range": {
            "type": "integer",
            "format": "int32"
          },
          "movement": {
            "type": "integer",
            "format": "int32"
          },
          "health": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "xPosition": {
            "type": "integer",
            "format": "int32"
          },
          "yPosition": {
            "type": "integer",
            "format": "int32"
          },
          "isDead": {
            "type": "boolean",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "UnitDefinition": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/UnitType"
          },
          "attack": {
            "type": "integer",
            "format": "int32"
          },
          "defence": {
            "type": "integer",
            "format": "int32"
          },
          "range": {
            "type": "integer",
            "format": "int32"
          },
          "movement": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "UnitType": {
        "enum": [
          0,
          1,
          2,
          3,
          4
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  }
